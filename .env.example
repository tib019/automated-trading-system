# Trading System - Umgebungsvariablen
# Kopieren Sie diese Datei zu .env und passen Sie die Werte an

# =============================================================================
# SICHERHEIT (ERFORDERLICH)
# =============================================================================

# Master-Passwort für Verschlüsselung (ÄNDERN SIE DIES!)
TRADING_MASTER_PASSWORD=your_secure_master_password_here

# Webhook-Secret für TradingView Integration (ÄNDERN SIE DIES!)
WEBHOOK_SECRET=your_webhook_secret_key_here

# =============================================================================
# API-SCHLÜSSEL (OPTIONAL FÜR ERWEITERTE FEATURES)
# =============================================================================

# OpenAI API für erweiterte Sentiment-Analyse (optional)
OPENAI_API_KEY=sk-your_openai_api_key_here
OPENAI_API_BASE=https://api.openai.com/v1

# =============================================================================
# BROKER-INTEGRATION (FÜR LIVE-TRADING)
# =============================================================================

# Binance API (für Live-Trading - VORSICHTIG VERWENDEN!)
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_SECRET_KEY=your_binance_secret_key_here
BINANCE_TESTNET=true  # Auf false für Live-Trading setzen

# Interactive Brokers (falls verwendet)
IB_HOST=127.0.0.1
IB_PORT=7497
IB_CLIENT_ID=1

# =============================================================================
# SOCIAL MEDIA APIs (FÜR SENTIMENT-ANALYSE)
# =============================================================================

# Twitter API v2 (optional)
TWITTER_BEARER_TOKEN=your_twitter_bearer_token_here

# Reddit API (optional)
REDDIT_CLIENT_ID=your_reddit_client_id_here
REDDIT_CLIENT_SECRET=your_reddit_client_secret_here
REDDIT_USER_AGENT=TradingBot/1.0

# =============================================================================
# DATENBANK-KONFIGURATION
# =============================================================================

# SQLite (Standard - keine Änderung erforderlich)
DATABASE_URL=sqlite:///data/trading_system.db

# PostgreSQL (für Produktionsumgebungen)
# DATABASE_URL=postgresql://user:password@localhost:5432/trading_system

# =============================================================================
# SYSTEM-KONFIGURATION
# =============================================================================

# Flask-Konfiguration
FLASK_ENV=production
FLASK_DEBUG=false
SECRET_KEY=your_flask_secret_key_here

# API-Konfiguration
API_HOST=0.0.0.0
API_PORT=5001

# Dashboard-Konfiguration
DASHBOARD_PORT=3000

# =============================================================================
# LOGGING UND MONITORING
# =============================================================================

# Log-Level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Log-Datei-Pfad
LOG_FILE=logs/trading_system.log

# Monitoring-Konfiguration
ENABLE_MONITORING=true
METRICS_PORT=9090

# =============================================================================
# TRADING-PARAMETER
# =============================================================================

# Standard-Positionsgröße (% des Portfolios)
DEFAULT_POSITION_SIZE=2.0

# Maximale Anzahl offener Positionen
MAX_OPEN_POSITIONS=10

# Kill-Switch-Schwellenwert (% Verlust)
KILL_SWITCH_THRESHOLD=15.0

# =============================================================================
# RATE-LIMITING
# =============================================================================

# API-Rate-Limits (Requests pro Minute)
API_RATE_LIMIT=100
WEBHOOK_RATE_LIMIT=60
AUTH_RATE_LIMIT=5

# =============================================================================
# BACKUP UND WARTUNG
# =============================================================================

# Backup-Verzeichnis
BACKUP_DIR=backups

# Backup-Aufbewahrung (Tage)
BACKUP_RETENTION_DAYS=30

# Automatische Backups aktivieren
AUTO_BACKUP=true

# =============================================================================
# ENTWICKLUNG UND TESTING
# =============================================================================

# Testing-Modus (für Entwicklung)
TESTING_MODE=false

# Paper-Trading aktivieren
PAPER_TRADING=true

# Debug-Modus für detaillierte Logs
DEBUG_MODE=false

# =============================================================================
# SICHERHEITSHINWEISE
# =============================================================================

# WICHTIG:
# 1. Ändern Sie ALLE Passwörter und Secrets!
# 2. Verwenden Sie starke, zufällige Passwörter
# 3. Teilen Sie diese Datei NIEMALS öffentlich
# 4. Fügen Sie .env zur .gitignore hinzu
# 5. Starten Sie mit PAPER_TRADING=true
# 6. Testen Sie ausgiebig vor Live-Trading

# Passwort-Generator-Beispiel:
# python -c "import secrets; print(secrets.token_urlsafe(32))"

